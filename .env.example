# ==========================================
# VIRTUAL SMART HOME - ENVIRONMENT EXAMPLE
# ==========================================
# Copy to .env and modify as needed

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=virtual_smart_home
DB_PORT=3306

# Application Settings
APP_NAME="Virtual Smart Home"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/smart_home

# Virtual Device Settings
DEFAULT_DEVICES=5
SIMULATION_SPEED=normal
MAX_DEVICES=20
DEVICE_TIMEOUT=30

# Demo Mode
DEMO_MODE=true
AUTO_GENERATE_DATA=true

# Voice API (optional)
VOICE_API_ENABLED=false
VOICE_API_KEY=your_key_here